APP_NAME=zhomind-backend
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/zhomind_app
# Copy this file to backend/.env before running compose or the backend directly.
# Fill every blank value below with your local runtime configuration.
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=120
ADMIN_INVITE_CODE=
REDIS_URL=redis://redis:6379/0

# ===== ARK / LLM (provider-specific required values stay blank) =====
ARK_API_KEY=
MODEL=doubao-seed-2-0-pro-260215
GRADE_MODEL=doubao-seed-2-0-lite-260215
FAST_MODEL=doubao-seed-1-6-flash-250828
BASE_URL=

# ===== Embedding（远程 API；API key/base URL 按你的 provider 填写） =====
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
DENSE_EMBEDDING_DIM=1024

# ===== Rerank（可选，不配则自动降级） =====
RERANK_MODEL=jina-reranker-v3
RERANK_BINDING_HOST=
RERANK_API_KEY=

# ===== Milvus =====
MILVUS_URI=http://milvus:19530
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_TOKEN=

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_SECURE=false

# ===== RAG defaults (example values for local development) =====
RAG_GRAPH_ALIAS=default_v1
RAG_ENABLE_TOOLS=false
RAG_TOOL_MAX_CALLS=3
RAG_TOOL_MAX_PARALLEL=2
RAG_TOOL_TIMEOUT_MS=8000
RAG_DEFAULT_LLM_PROVIDER=chat-default-llm
RAG_PRIMARY_LLM_PROVIDER=ark
RAG_LLM_FALLBACK_PROVIDERS=openai,anthropic
RAG_DISABLE_GATE=true

# ===== Optional provider fallbacks =====
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# BM25 稀疏统计持久化（本地示例路径，可按需覆盖）
BM25_STATE_PATH=data/bm25_state.json
DOCUMENT_ALLOWED_EXTENSIONS=txt,md,pdf
DOC_WORKER_ENABLED=true
DOC_WORKER_MAX_CONCURRENCY=1
