APP_NAME=zhomind-backend
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/zhomind_app
JWT_SECRET=change-this-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=120
ADMIN_INVITE_CODE=
REDIS_URL=redis://redis:6379/0
MILVUS_URI=http://milvus:19530
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
RAG_GRAPH_ALIAS=default_v1
RAG_ENABLE_TOOLS=false
RAG_TOOL_MAX_CALLS=3
RAG_TOOL_MAX_PARALLEL=2
RAG_TOOL_TIMEOUT_MS=8000
RAG_DEFAULT_LLM_PROVIDER=chat-default-llm
